# NVD API Key (optional but strongly recommended)
# Without key: 5 req/30s — processing 50 CVEs takes ~5 minutes
# With key:   50 req/30s — processing 50 CVEs takes ~35 seconds
# Free registration: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Google OAuth credentials for Sheets export (optional)
# Download credentials.json from Google Cloud Console → APIs & Services → Credentials
# token.json is auto-generated on first run via browser OAuth flow
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Custom User-Agent for ExploitDB scraping (optional)
EXPLOITDB_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
